# Application
APP_NAME=AniVibe
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
AUTH_REQUIRED=true

# Neon/Postgres
DATABASE_URL=postgresql+asyncpg://user:password@host-pooler.region.aws.neon.tech/anivibe?ssl=require
DATABASE_MIGRATION_URL=postgresql://user:password@host.region.aws.neon.tech/anivibe?ssl=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Clerk
CLERK_ISSUER=https://your-production-clerk-domain
CLERK_JWKS_URL=https://your-production-clerk-domain/.well-known/jwks.json
CLERK_SECRET_KEY=sk_live_replace_me

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=anivibe-media
R2_PUBLIC_BASE_URL=https://media.yourdomain.com

# Upstash Redis
REDIS_URL=rediss://default:password@host.upstash.io:6379
REDIS_REQUIRED=true

# External APIs
JIKAN_API_URL=https://api.jikan.moe/v4
ANILIST_API_URL=https://graphql.anilist.co
GEMINI_API_KEY=your-production-gemini-key
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# ML service
ML_SERVICE_URL=https://your-modal-app.modal.run
ENABLE_IMAGE_SEARCH=false
ENABLE_GNN=false
ENABLE_BERT4REC=false
USE_GPU=false
MODEL_CACHE_DIR=/app/models/cache
SBERT_MODEL_NAME=all-MiniLM-L6-v2
CLIP_MODEL_NAME=ViT-B-32

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# CORS
CORS_ORIGINS=https://anivibe.vercel.app,https://www.anivibe.com
CORS_ALLOW_CREDENTIALS=true
