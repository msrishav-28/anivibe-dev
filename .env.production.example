# Production Environment Configuration

# Application
APP_NAME=AniVibe
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=False
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=False

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database - PostgreSQL
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=anivibe_prod
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=anivibe_production

# Database - MongoDB
MONGODB_HOST=your-mongodb-host
MONGODB_PORT=27017
MONGODB_USER=anivibe_prod
MONGODB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
MONGODB_DB=anivibe_embeddings_prod

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# External APIs
JIKAN_API_URL=https://api.jikan.moe/v4
ANILIST_API_URL=https://graphql.anilist.co
GEMINI_API_KEY=your-production-gemini-key
OPENAI_API_KEY=your-production-openai-key

# OAuth
MAL_CLIENT_ID=your-mal-production-client-id
MAL_CLIENT_SECRET=your-mal-production-secret
ANILIST_CLIENT_ID=your-anilist-production-client-id
ANILIST_CLIENT_SECRET=your-anilist-production-secret
ANILIST_REDIRECT_URI=https://yourdomain.com/api/v1/auth/anilist/callback

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ML Models
MODEL_CACHE_DIR=/app/models/cache
EMBEDDINGS_DIR=/app/data/embeddings
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
SBERT_MODEL_NAME=all-mpnet-base-v2
SENTIMENT_MODEL_NAME=distilbert-base-uncased

# FAISS
FAISS_INDEX_PATH=/app/data/faiss_indexes
FAISS_NLIST=100

# Recommendations
TOP_K_RECOMMENDATIONS=10
SIMILARITY_THRESHOLD=0.5
POPULARITY_ATTENUATION_FACTOR=0.3

# MLflow
MLFLOW_TRACKING_URI=https://your-mlflow-server.com
MLFLOW_EXPERIMENT_NAME=anivibe-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/anivibe.log

# CORS
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=True

# Batch Processing
BATCH_SIZE=32
MAX_WORKERS=4

# GPU
USE_GPU=True
GPU_DEVICE=cuda:0
