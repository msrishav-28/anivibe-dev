# ============================================
# ANIVIBE CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=AniVibe
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Security (still needed for some internal operations)
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard > Settings > API

# Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe for frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (SERVER SIDE ONLY - never expose to frontend!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# REDIS (for caching - optional for development)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery (for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# EXTERNAL API KEYS
# ============================================
JIKAN_API_URL=https://api.jikan.moe/v4
ANILIST_API_URL=https://graphql.anilist.co
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# MyAnimeList OAuth (optional)
MAL_CLIENT_ID=your-mal-client-id
MAL_CLIENT_SECRET=your-mal-client-secret

# AniList OAuth (optional)
ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret
ANILIST_REDIRECT_URI=http://localhost:8000/api/v1/auth/anilist/callback

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============================================
# ML MODELS CONFIGURATION
# ============================================
MODEL_CACHE_DIR=./models/cache
EMBEDDINGS_DIR=./data/embeddings

# CLIP
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai

# BERT/SBERT
SBERT_MODEL_NAME=all-mpnet-base-v2

# Sentiment
SENTIMENT_MODEL_NAME=distilbert-base-uncased

# FAISS
FAISS_INDEX_PATH=./data/faiss_indexes
FAISS_NLIST=100

# ============================================
# RECOMMENDATION SETTINGS
# ============================================
TOP_K_RECOMMENDATIONS=10
SIMILARITY_THRESHOLD=0.5
POPULARITY_ATTENUATION_FACTOR=0.3

# ============================================
# MLFLOW (optional)
# ============================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=anivibe-experiments

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/anivibe.log

# ============================================
# CORS
# ============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE=10485760

# ============================================
# BATCH PROCESSING
# ============================================
BATCH_SIZE=32
MAX_WORKERS=4

# ============================================
# GPU CONFIGURATION
# ============================================
USE_GPU=True
GPU_DEVICE=cuda:0
