# Application
APP_NAME=AniVibe
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=anivibe
POSTGRES_PASSWORD=anivibe_password
POSTGRES_DB=anivibe_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Database - MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=anivibe
MONGODB_PASSWORD=anivibe_password
MONGODB_DB=anivibe_embeddings
MONGODB_URL=mongodb://${MONGODB_USER}:${MONGODB_PASSWORD}@${MONGODB_HOST}:${MONGODB_PORT}/${MONGODB_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API Keys - External Services
JIKAN_API_URL=https://api.jikan.moe/v4
ANILIST_API_URL=https://graphql.anilist.co
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# MyAnimeList OAuth
MAL_CLIENT_ID=your-mal-client-id
MAL_CLIENT_SECRET=your-mal-client-secret

# AniList OAuth
ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret
ANILIST_REDIRECT_URI=http://localhost:8000/api/v1/auth/anilist/callback

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ML Models Configuration
MODEL_CACHE_DIR=./models/cache
EMBEDDINGS_DIR=./data/embeddings

# CLIP Configuration
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai

# BERT Configuration
SBERT_MODEL_NAME=all-mpnet-base-v2
# SBERT_MODEL_NAME=all-MiniLM-L6-v2  # Lighter alternative

# Sentiment Model
SENTIMENT_MODEL_NAME=distilbert-base-uncased

# FAISS Configuration
FAISS_INDEX_PATH=./data/faiss_indexes
FAISS_NLIST=100  # Number of clusters for IVF

# Recommendation Settings
TOP_K_RECOMMENDATIONS=10
SIMILARITY_THRESHOLD=0.5
POPULARITY_ATTENUATION_FACTOR=0.3

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=anivibe-experiments

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/anivibe.log

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Batch Processing
BATCH_SIZE=32
MAX_WORKERS=4

# GPU Configuration
USE_GPU=True
GPU_DEVICE=cuda:0
