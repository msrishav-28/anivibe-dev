# ==========================================
# APPLICATION
# ==========================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ==========================================
# SUPABASE (Single Source of Truth)
# ==========================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# ==========================================
# REDIS (Caching)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# EXTERNAL APIs
# ==========================================
GEMINI_API_KEY=your-gemini-api-key

# OAuth (Optional - for MAL/AniList sync)
MAL_CLIENT_ID=your-mal-client-id
MAL_CLIENT_SECRET=your-mal-client-secret
ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret

# ==========================================
# ML SERVICE (Future)
# ==========================================
ML_SERVICE_URL=http://localhost:8080

# Feature Flags
ENABLE_IMAGE_SEARCH=false
ENABLE_GNN=false
ENABLE_BERT4REC=false

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==========================================
# GPU (Set to false if no GPU available)
# ==========================================
USE_GPU=false
