# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
AUTH_REQUIRED=false
DEV_AUTH_HEADER=X-AniVibe-Dev-User
DEV_AUTH_DEFAULT_USER=local-user

# Neon/Postgres
# Local Docker Postgres/pgvector. Use postgres:5432 instead of localhost
# when the backend itself runs inside docker-compose.
DATABASE_URL=postgresql+asyncpg://anivibe:anivibe@localhost:5432/anivibe
DATABASE_MIGRATION_URL=postgresql://anivibe:anivibe@localhost:5432/anivibe

# Clerk
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=sk_test_replace_me

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=anivibe-media
R2_PUBLIC_BASE_URL=https://media.example.com

# Redis / Upstash
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=false
RATE_LIMIT_ENABLED=true

# External APIs
GEMINI_API_KEY=
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# ML service
ML_SERVICE_URL=http://localhost:8080
ENABLE_IMAGE_SEARCH=false
ENABLE_GNN=false
ENABLE_BERT4REC=false
USE_GPU=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
